{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/job-mapper",
      "destination": "https://job-map-express.vercel.app/job-mapper"
    },
    {
      "source": "/job-mapper/:path*",
      "destination": "https://job-map-express.vercel.app/job-mapper/:path*"
    },
    {
      "source": "/venture-proof",
      "destination": "https://web-alpha-rouge-61.vercel.app/venture-proof"
    },
    {
      "source": "/venture-proof/:path*",
      "destination": "https://web-alpha-rouge-61.vercel.app/venture-proof/:path*"
    },
    {
      "source": "/login",
      "destination": "https://web-alpha-rouge-61.vercel.app/venture-proof/login"
    },
    {
      "source": "/pricing",
      "destination": "https://web-alpha-rouge-61.vercel.app/venture-proof/pricing"
    },
    {
      "source": "/api/auth/:path*",
      "destination": "https://web-alpha-rouge-61.vercel.app/venture-proof/api/auth/:path*"
    },
    {
      "source": "/xchange",
      "destination": "https://x402-gray.vercel.app/xchange"
    },
    {
      "source": "/xchange/:path*",
      "destination": "https://x402-gray.vercel.app/xchange/:path*"
    },
    {
      "source": "/",
      "destination": "/index.html"
    }
  ]
}